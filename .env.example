APP_NAME=Chatbot Backend
APP_VERSION=1.1.0
DEPLOYMENT_ENV=development
DEBUG=true

HOST=0.0.0.0
PORT=8000

ENABLE_JWT_AUTH=true
JWT_SECRET=super-secret-jwt-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

DEMO_AUTH_USERNAME=admin
DEMO_AUTH_PASSWORD=password

CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

MAX_UPLOAD_SIZE_MB=25
MAX_INPUT_TEXT_CHARS=200000

OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4.1-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_MODEL_ID=global.amazon.nova-2-lite-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=pdf_documents

S3_VECTORS_BUCKET=your-bucket-name
S3_VECTORS_INDEX_NAME=your-vector-index-name
S3_VECTORS_REGION=us-east-1

DEFAULT_MAX_TOKENS=1000
DEFAULT_TEMPERATURE=0.7
DEFAULT_TOP_P=1.0

DEFAULT_CHUNK_SIZE=1200
DEFAULT_CHUNK_OVERLAP=200